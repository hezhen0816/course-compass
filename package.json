{
  "name": "course-planner-workspace",
  "private": true,
  "scripts": {
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "web:lint": "npm --prefix web run lint",
    "dev": "npm run web:dev",
    "build": "npm run web:build",
    "lint": "npm run web:lint",
    "backend:dev": "python3 -m uvicorn backend.app:app --reload --host 0.0.0.0 --port 8000 --env-file .env",
    "ios:open": "open ios/App/App.xcodeproj",
    "ios:build": "xcodebuild -project ios/App/App.xcodeproj -scheme App -configuration Debug -sdk iphonesimulator -destination 'generic/platform=iOS Simulator' CODE_SIGNING_ALLOWED=NO build"
  }
}
